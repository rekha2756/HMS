# ========================
# SERVER CONFIGURATION
# ========================
PORT=5000
NODE_ENV=development          # Change to 'production' when live

# ========================
# DATABASE (Multi‑tenant)
# ========================
DB_HOST=localhost
DB_USER=root                  # Your actual MySQL user
DB_PASSWORD=Ashokacollege@123        # Your actual MySQL password
DB_CONNECTION_LIMIT=10

# Central registry database (stores tenant metadata, audit logs)
TENANT_REGISTRY_DB=tenant_registry

# ========================
# JWT AUTHENTICATION (RS256)
# ========================
JWT_PRIVATE_KEY_PATH=./keys/private_key.pem
JWT_PUBLIC_KEY_PATH=./keys/public_key.pem
ACCESS_TOKEN_EXPIRY=1h        # ✅ changed from 15m to 1h
REFRESH_TOKEN_EXPIRY=30d      # ✅ changed from 7d to 30d

# Cookie settings (set secure=false for local development)
COOKIE_SECURE=false           # Change to true when using HTTPS
COOKIE_SAME_SITE=lax

# ========================
# OTP SERVICE (Optional – add later)
# ========================
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASSWORD=
EMAIL_FROM=noreply@yourhospital.com
OTP_EXPIRY=300

# ========================
# PAYMENT GATEWAY (Optional – add later)
# ========================
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ========================
# CHATBOT (Python microservice – optional)
# ========================
CHATBOT_API_URL=http://localhost:5001/chat
CHATBOT_API_KEY=change_this_to_a_random_string

# ========================
# SECURITY & ENCRYPTION
# ========================
# Generate a random 32-byte hex key (run: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
ENCRYPTION_KEY=5192aa6a419535e7bc98bc49ac4f7ac055f8d33bcbeb41fc7e2914f1886a4157
ENCRYPTION_IV=1234567890abcdef12345678

# ========================
# RATE LIMITING (No Redis required for single server)
# ========================
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Redis (optional – for distributed rate limiting)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ========================
# CORS & FRONTEND
# ========================
FRONTEND_URL=http://localhost:3000

# ========================
# LOGGING & MONITORING
# ========================
SENTRY_DSN=

# ========================
# MISCELLANEOUS
# ========================
SESSION_SECRET=10a3e5739083831927306f3cd60c82a5df0ea4164ced150adfbfd3e0c0a65f3d01e3878c478032570b98e2846c67e552b12576a728e644420994e8afcb5006d3
ADMIN_EMAIL=admin@yourhospital.com